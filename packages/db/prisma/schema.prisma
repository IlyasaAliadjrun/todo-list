// Prisma schema — satu-satunya jalur ke database (lihat docs/architecture.md).
// Fase 1: Auth & Workspace. Fase 2: Page & hierarki (sidebar tree).
// Fase 4: Database sederhana (table view).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum PropertyType {
  TEXT
  NUMBER
  SELECT
  MULTI_SELECT
  CHECKBOX
  DATE
  URL
}

enum PermissionLevel {
  VIEW
  COMMENT
  EDIT
}

enum PermissionSubject {
  USER
  WORKSPACE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions        Session[]
  memberships     WorkspaceMember[]
  sentInvitations WorkspaceInvitation[] @relation("InvitedBy")
  createdPages    Page[]               @relation("PageAuthor")
  favorites       Favorite[]
}

/// Refresh-token session. Token disimpan HANYA sebagai hash; rotasi menandai
/// revokedAt dan menautkan replacedById ke sesi penggantinya.
model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  userAgent    String?
  ip           String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Workspace {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  type      WorkspaceType @default(TEAM)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]
  pages       Page[]
  databases   Database[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

/// Undangan anggota. Fase 1 belum kirim email sungguhan — token undangan
/// dikembalikan lewat API dan bisa di-accept. Token disimpan sebagai hash.
model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        WorkspaceRole @default(MEMBER)
  tokenHash   String        @unique
  expiresAt   DateTime
  invitedById String
  invitedBy   User          @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([workspaceId])
  @@index([email])
}

/// Halaman bersarang (nested pages). Urutan antar-saudara disimpan sebagai
/// fractional index (string) agar reorder/re-parent cukup update 1 baris.
/// Trash = isArchived true; hapus permanen meng-cascade ke turunan.
model Page {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Page?     @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Page[]    @relation("PageTree")
  title       String    @default("Untitled")
  icon        String?
  coverUrl    String?
  content     Json?
  /// Snapshot biner dokumen Yjs (sumber kebenaran real-time, lihat ADR 0007).
  yjsState    Bytes?
  /// Teks polos hasil ekstraksi konten (untuk full-text search, lihat ADR 0009).
  searchText  String    @default("")
  /// tsvector (title + searchText) di-maintain oleh trigger; hanya lewat SQL raw.
  searchVector Unsupported("tsvector")?
  order       String
  createdById String
  createdBy   User      @relation("PageAuthor", fields: [createdById], references: [id])
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  databases   Database[]
  permissions PagePermission[]
  favorites   Favorite[]

  @@index([workspaceId, parentId, order])
  @@index([workspaceId, isArchived])
  @@index([searchVector], type: Gin)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, pageId])
  @@index([userId])
}

/// Akses per halaman untuk seorang user atau seluruh workspace. Diwarisi ke
/// sub-page kecuali di-override (lihat ADR 0008).
model PagePermission {
  id          String            @id @default(cuid())
  pageId      String
  page        Page              @relation(fields: [pageId], references: [id], onDelete: Cascade)
  subjectType PermissionSubject
  /// userId (USER) atau workspaceId (WORKSPACE).
  subjectId   String
  level       PermissionLevel   @default(VIEW)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([pageId, subjectType, subjectId])
  @@index([pageId])
}

/// Database sederhana (table view) — disisipkan sebagai block di sebuah page.
model Database {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pageId      String?
  page        Page?     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String    @default("Untitled")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  properties DatabaseProperty[]
  rows       DatabaseRow[]

  @@index([workspaceId])
  @@index([pageId])
}

model DatabaseProperty {
  id         String       @id @default(cuid())
  databaseId String
  database   Database     @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  name       String       @default("Kolom")
  type       PropertyType @default(TEXT)
  /// Untuk SELECT/MULTI_SELECT: array { id, name, color? }.
  options    Json?
  order      String
  createdAt  DateTime     @default(now())

  cells CellValue[]

  @@index([databaseId, order])
}

model DatabaseRow {
  id         String   @id @default(cuid())
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  order      String
  createdAt  DateTime @default(now())

  cells CellValue[]

  @@index([databaseId, order])
}

model CellValue {
  id         String           @id @default(cuid())
  rowId      String
  row        DatabaseRow      @relation(fields: [rowId], references: [id], onDelete: Cascade)
  propertyId String
  property   DatabaseProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  value      Json?
  updatedAt  DateTime         @updatedAt

  @@unique([rowId, propertyId])
  @@index([propertyId])
}
