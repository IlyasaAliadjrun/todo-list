# Caddyfile — reverse proxy TLS di depan stack produksi (lihat docker-compose.prod.yml).
#
# TLS memakai sertifikat SENDIRI (bukan Let's Encrypt). Taruh dua file di ./certs/ pada
# host (ter-mount ke /etc/caddy/certs, lihat compose):
#   - fullchain.pem : sertifikat leaf + SEMUA intermediate (leaf paling atas). Tanpa
#                     rantai lengkap, sebagian browser/perangkat menolak.
#   - privkey.pem   : private key PEM TANPA passphrase (Caddy tak bisa key terenkripsi).
# Sertifikat harus mencakup nama "notes.akasha.co.id" (atau wildcard *.akasha.co.id).
#
# SATU domain untuk semua: SPA + REST + WebSocket /collab, DAN object storage (path bucket).
#
# Uji lokal tanpa TLS: set APP_DOMAIN=http://localhost dan hapus baris `tls` di bawah
# (skema http:// membuat Caddy melayani HTTP polos).

{$APP_DOMAIN} {
	# Sertifikat sendiri — memberi file eksplisit MEMATIKAN ACME/Let's Encrypt.
	# Perpanjangan jadi tanggung jawabmu: ganti file lalu `docker compose ... restart caddy`.
	tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.pem

	# Object storage: path bucket MinIO di-proxy langsung ke MinIO agar browser bisa
	# GET (lihat) & PUT (upload presigned) gambar. Pakai `handle` (BUKAN handle_path)
	# supaya path penuh /<bucket>/... TIDAK dipangkas — signature SigV4 mencakup path
	# dan Host, keduanya harus utuh. Caddy mempertahankan Host asli secara default, jadi
	# signature yang ditandatangani API (terhadap S3_PUBLIC_ENDPOINT = domain ini) tetap valid.
	# Default bucket "notion-uploads" mengikuti S3_BUCKET (lihat docker-compose.prod.yml).
	handle /{$S3_BUCKET:notion-uploads}/* {
		# MAX_UPLOAD_BYTES = 10MB (packages/shared/src/storage/upload.ts) + headroom.
		request_body {
			max_size 12MB
		}
		reverse_proxy minio:9000
	}

	# Sisanya → Nginx (apps/web/nginx.conf) → api:3001.
	# X-Forwarded-For tak perlu diatur manual: `trusted_proxies` tidak diset, sehingga Caddy
	# MENGGANTI (bukan menambah) XFF kiriman klien dengan IP asli — klien tak bisa memalsukan
	# IP. API membaca rantai ini untuk rate-limit per-IP; lihat "trust proxy" di main.ts.
	handle {
		reverse_proxy web:80
	}
}
