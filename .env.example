# ------------------------------------------------------------------
# .env.example — salin ke .env lalu sesuaikan.
# JANGAN commit .env yang berisi nilai asli.
# ------------------------------------------------------------------

# --- App ---
NODE_ENV=development
API_PORT=3001
WEB_PORT=5173
WEB_ORIGIN=http://localhost:5173          # dipakai untuk CORS di API
HOCUSPOCUS_URL=ws://localhost:3001/collab # endpoint WebSocket kolaborasi Yjs

# --- PostgreSQL ---
# Nilai ini dipakai oleh container postgres DAN dirangkai ke DATABASE_URL.
POSTGRES_USER=notion
POSTGRES_PASSWORD=notion_dev_password     # GANTI untuk non-lokal
POSTGRES_DB=notion
POSTGRES_HOST=localhost                   # di dalam container lain gunakan "postgres"
POSTGRES_PORT=5432
DATABASE_URL=postgresql://notion:notion_dev_password@localhost:5432/notion?schema=public

# --- Redis ---
REDIS_HOST=localhost                      # di dalam container lain gunakan "redis"
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO / S3-compatible) ---
S3_ENDPOINT=http://localhost:9000         # di dalam container lain gunakan http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=notion-uploads
S3_ACCESS_KEY=minioadmin                  # GANTI untuk non-lokal
S3_SECRET_KEY=minioadmin_dev_password     # GANTI untuk non-lokal
S3_FORCE_PATH_STYLE=true                  # wajib true untuk MinIO
# Endpoint yang diakses BROWSER untuk presigned/public URL. Dev: sama dgn S3_ENDPOINT.
# Di container (API pakai http://minio:9000 internal), set ke host publik, mis:
# S3_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_PORT=9001

# --- Auth (JWT) ---
# Buat secret acak, mis: openssl rand -hex 32
JWT_ACCESS_SECRET=ganti_dengan_secret_acak_panjang
JWT_REFRESH_SECRET=ganti_dengan_secret_acak_panjang_berbeda
JWT_ACCESS_TTL=900                        # detik (15 menit)
JWT_REFRESH_TTL=1209600                   # detik (14 hari)

# --- Observability & hardening ---
# SENTRY_DSN=
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=600                     # rate limit global per IP (anti-abuse kasar)

# --- Email (SMTP, nodemailer) ---
# Bila MAIL_HOST kosong, email dinonaktifkan (undangan tetap jalan via token).
# Produksi: isi kredensial provider (Resend/Mailgun/SendGrid/SES/Gmail).
# APP_URL dipakai untuk membentuk link undangan (default = WEB_ORIGIN).
# APP_URL=https://app.domain.com
# MAIL_HOST=smtp.resend.com          # contoh Resend; Mailgun: smtp.mailgun.org, dsb.
# MAIL_PORT=587
# MAIL_SECURE=false                  # true untuk port 465 (SMTPS)
# MAIL_USER=resend                   # Resend: "resend"; provider lain: user/API key id
# MAIL_PASS=re_xxxxxxxxxxxx          # password/API key SMTP
# MAIL_FROM=My Notepad <no-reply@domain.com>   # WAJIB domain terverifikasi di produksi
